{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Kernel",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "./scripts/build-kernel.ps1"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build Test Harness",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "./scripts/build-host.ps1"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run in QEMU",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "./scripts/run-qemu.ps1"
            ],
            "group": "test",
            "problemMatcher": []
        }
    ]
}